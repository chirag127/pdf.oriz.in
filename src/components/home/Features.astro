---
// Features section
---

<section class="py-16 sm:py-20 bg-white">
	<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
		<div class="text-center mb-14">
			<h2 class="font-display text-3xl sm:text-4xl font-bold text-gray-900 tracking-tight mb-4">
				Why OrizPDF?
			</h2>
			<p class="text-lg text-gray-600 max-w-xl mx-auto">
				Built from the ground up to protect your privacy while delivering professional results.
			</p>
		</div>

		<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
			<!-- Feature 1 -->
			<div class="group p-6 rounded-2xl bg-gradient-to-br from-green-50 to-emerald-50/50 border border-green-100 hover:shadow-lg transition-all duration-300">
				<div class="flex items-center justify-center size-12 rounded-xl bg-green-100 mb-4">
					<svg class="size-6 text-green-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
						<path d="M9 12l2 2 4-4"/>
					</svg>
				</div>
				<h3 class="font-display text-lg font-semibold text-gray-900 mb-2">100% Private</h3>
				<p class="text-sm text-gray-600 leading-relaxed">
					All processing happens in your browser. Files never touch our servers. We literally cannot see your documents.
				</p>
			</div>

			<!-- Feature 2 -->
			<div class="group p-6 rounded-2xl bg-gradient-to-br from-blue-50 to-indigo-50/50 border border-blue-100 hover:shadow-lg transition-all duration-300">
				<div class="flex items-center justify-center size-12 rounded-xl bg-blue-100 mb-4">
					<svg class="size-6 text-blue-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
					</svg>
				</div>
				<h3 class="font-display text-lg font-semibold text-gray-900 mb-2">Lightning Fast</h3>
				<p class="text-sm text-gray-600 leading-relaxed">
					Powered by WebAssembly and optimized JavaScript. Process PDFs in seconds, not minutes.
				</p>
			</div>

			<!-- Feature 3 -->
			<div class="group p-6 rounded-2xl bg-gradient-to-br from-orange-50 to-amber-50/50 border border-orange-100 hover:shadow-lg transition-all duration-300">
				<div class="flex items-center justify-center size-12 rounded-xl bg-orange-100 mb-4">
					<svg class="size-6 text-orange-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<circle cx="12" cy="12" r="10"/>
						<path d="M16 8l-8 8M8 8l8 8"/>
					</svg>
				</div>
				<h3 class="font-display text-lg font-semibold text-gray-900 mb-2">Always Free</h3>
				<p class="text-sm text-gray-600 leading-relaxed">
					No hidden fees, no premium tiers, no credit card. Every tool is completely free, forever.
				</p>
			</div>

			<!-- Feature 4 -->
			<div class="group p-6 rounded-2xl bg-gradient-to-br from-purple-50 to-violet-50/50 border border-purple-100 hover:shadow-lg transition-all duration-300">
				<div class="flex items-center justify-center size-12 rounded-xl bg-purple-100 mb-4">
					<svg class="size-6 text-purple-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<circle cx="12" cy="12" r="10"/>
						<line x1="2" y1="12" x2="22" y2="12"/>
						<path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/>
					</svg>
				</div>
				<h3 class="font-display text-lg font-semibold text-gray-900 mb-2">Works Everywhere</h3>
				<p class="text-sm text-gray-600 leading-relaxed">
					Any browser, any device. Desktop, tablet, or phone — just open and use.
				</p>
			</div>

			<!-- Feature 5 -->
			<div class="group p-6 rounded-2xl bg-gradient-to-br from-violet-50 to-fuchsia-50/50 border border-violet-100 hover:shadow-lg transition-all duration-300">
				<div class="flex items-center justify-center size-12 rounded-xl bg-violet-100 mb-4">
					<svg class="size-6 text-violet-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<path d="M12 3l1.912 5.813a2 2 0 001.275 1.275L21 12l-5.813 1.912a2 2 0 00-1.275 1.275L12 21l-1.912-5.813a2 2 0 00-1.275-1.275L3 12l5.813-1.912a2 2 0 001.275-1.275L12 3z"/>
					</svg>
				</div>
				<h3 class="font-display text-lg font-semibold text-gray-900 mb-2">AI Powered</h3>
				<p class="text-sm text-gray-600 leading-relaxed">
					Smart features powered by AI — from document summarization to intelligent OCR text recognition.
				</p>
			</div>

			<!-- Feature 6 -->
			<div class="group p-6 rounded-2xl bg-gradient-to-br from-teal-50 to-cyan-50/50 border border-teal-100 hover:shadow-lg transition-all duration-300">
				<div class="flex items-center justify-center size-12 rounded-xl bg-teal-100 mb-4">
					<svg class="size-6 text-teal-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
						<polyline points="14 2 14 8 20 8"/>
						<line x1="16" y1="13" x2="8" y2="13"/>
						<line x1="16" y1="17" x2="8" y2="17"/>
					</svg>
				</div>
				<h3 class="font-display text-lg font-semibold text-gray-900 mb-2">30+ Tools</h3>
				<p class="text-sm text-gray-600 leading-relaxed">
					Everything you need in one place — merge, split, convert, edit, sign, compress, and more.
				</p>
			</div>
		</div>
	</div>
</section>
