---
// Hero section for homepage
---

<section class="relative overflow-hidden bg-gradient-to-br from-white via-blue-50/30 to-indigo-50/50">
	<!-- Background decoration -->
	<div class="absolute inset-0 pointer-events-none overflow-hidden">
		<div class="absolute top-0 right-0 w-[600px] h-[600px] bg-blue-200/20 rounded-full blur-3xl -translate-y-1/2 translate-x-1/4"></div>
		<div class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-indigo-200/15 rounded-full blur-3xl translate-y-1/3 -translate-x-1/4"></div>
		<!-- Dot pattern -->
		<div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle at 1px 1px, #3b82f6 1px, transparent 0); background-size: 32px 32px;"></div>
	</div>

	<div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pt-20 pb-24 sm:pt-28 sm:pb-32">
		<div class="max-w-3xl mx-auto text-center">
			<!-- Trust badge -->
			<div class="inline-flex items-center gap-2 px-4 py-1.5 bg-blue-100/80 border border-blue-200/60 rounded-full mb-6">
				<span class="size-2 rounded-full bg-green-500 animate-pulse"></span>
				<span class="text-sm font-medium text-blue-700">No uploads. No tracking. 100% browser-based.</span>
			</div>

			<h1 class="font-display text-4xl sm:text-5xl lg:text-6xl font-bold text-gray-900 tracking-tight leading-[1.1] mb-6">
				All the PDF tools<br/>
				<span class="bg-gradient-to-r from-blue-600 to-indigo-600 bg-clip-text text-transparent">you need</span>
			</h1>

			<p class="text-lg sm:text-xl text-gray-600 leading-relaxed mb-10 max-w-2xl mx-auto">
				30+ free tools to merge, split, compress, convert, and edit PDFs.
				Everything runs in your browser — your files never leave your device.
			</p>

			<div class="flex flex-col sm:flex-row items-center justify-center gap-4">
				<a
					href="#tools"
					class="inline-flex items-center gap-2 px-8 py-3.5 bg-blue-600 text-white font-semibold rounded-xl hover:bg-blue-700 transition-all hover:-translate-y-0.5 hover:shadow-lg hover:shadow-blue-500/25 text-base"
				>
					Choose a Tool
					<svg class="size-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
						<path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
					</svg>
				</a>
				<a
					href="#how-it-works"
					class="inline-flex items-center gap-2 px-8 py-3.5 bg-white text-gray-700 font-semibold rounded-xl border border-gray-300 hover:border-gray-400 hover:bg-gray-50 transition-all text-base"
				>
					How It Works
				</a>
			</div>

			<!-- Trust indicators -->
			<div class="flex items-center justify-center gap-6 mt-10 text-sm text-gray-500">
				<div class="flex items-center gap-1.5">
					<svg class="size-4 text-green-500" fill="currentColor" viewBox="0 0 20 20">
						<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
					</svg>
					Free forever
				</div>
				<div class="flex items-center gap-1.5">
					<svg class="size-4 text-green-500" fill="currentColor" viewBox="0 0 20 20">
						<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
					</svg>
					No registration
				</div>
				<div class="flex items-center gap-1.5">
					<svg class="size-4 text-green-500" fill="currentColor" viewBox="0 0 20 20">
						<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
					</svg>
					Private & secure
				</div>
			</div>
		</div>
	</div>
</section>
