---
// How It Works section
---

<section id="how-it-works" class="py-16 sm:py-20 bg-slate-50/50">
	<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
		<div class="text-center mb-14">
			<h2 class="font-display text-3xl sm:text-4xl font-bold text-gray-900 tracking-tight mb-4">
				How It Works
			</h2>
			<p class="text-lg text-gray-600 max-w-xl mx-auto">
				Three simple steps. No sign-up required.
			</p>
		</div>

		<div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-4xl mx-auto">
			<!-- Step 1 -->
			<div class="relative flex flex-col items-center text-center">
				<div class="flex items-center justify-center size-16 rounded-2xl bg-blue-600 text-white mb-5 shadow-lg shadow-blue-500/20">
					<svg class="size-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/>
						<polyline points="17 8 12 3 7 8"/>
						<line x1="12" y1="3" x2="12" y2="15"/>
					</svg>
				</div>
				<h3 class="font-display text-lg font-semibold text-gray-900 mb-2">
					Upload your file
				</h3>
				<p class="text-sm text-gray-600 leading-relaxed">
					Drag and drop or click to browse. Your files stay on your device — always.
				</p>
			</div>

			<!-- Step 2 -->
			<div class="relative flex flex-col items-center text-center">
				<div class="flex items-center justify-center size-16 rounded-2xl bg-indigo-600 text-white mb-5 shadow-lg shadow-indigo-500/20">
					<svg class="size-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<circle cx="12" cy="12" r="3"/>
						<path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-2 2 2 2 0 01-2-2v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83 0 2 2 0 010-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 01-2-2 2 2 0 012-2h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 010-2.83 2 2 0 012.83 0l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 012-2 2 2 0 012 2v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 0 2 2 0 010 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 012 2 2 2 0 01-2 2h-.09a1.65 1.65 0 00-1.51 1z"/>
					</svg>
				</div>
				<h3 class="font-display text-lg font-semibold text-gray-900 mb-2">
					Choose settings
				</h3>
				<p class="text-sm text-gray-600 leading-relaxed">
					Pick your options — page ranges, quality, rotation, and more.
				</p>
			</div>

			<!-- Step 3 -->
			<div class="relative flex flex-col items-center text-center">
				<div class="flex items-center justify-center size-16 rounded-2xl bg-emerald-600 text-white mb-5 shadow-lg shadow-emerald-500/20">
					<svg class="size-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/>
						<polyline points="7 10 12 15 17 10"/>
						<line x1="12" y1="15" x2="12" y2="3"/>
					</svg>
				</div>
				<h3 class="font-display text-lg font-semibold text-gray-900 mb-2">
					Download result
				</h3>
				<p class="text-sm text-gray-600 leading-relaxed">
					Click download — your processed file is ready instantly.
				</p>
			</div>
		</div>
	</div>
</section>
