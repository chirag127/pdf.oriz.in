---
import { tools, categories } from "../../data/tools";

const year = new Date().getFullYear();
---

<footer class="bg-gray-950 text-gray-400 mt-auto">
	<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16">
		<div class="grid grid-cols-2 md:grid-cols-4 gap-8 lg:gap-12">
			<!-- Brand Column -->
			<div class="col-span-2 md:col-span-1">
				<a href="/" class="flex items-center gap-2 mb-4">
					<div
						class="flex items-center justify-center size-9 rounded-lg bg-blue-600 text-white"
					>
						<svg
							viewBox="0 0 24 24"
							class="size-5"
							fill="none"
							stroke="currentColor"
							stroke-width="2.5"
							stroke-linecap="round"
							stroke-linejoin="round"
						>
							<path
								d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"
							></path>
							<polyline points="14 2 14 8 20 8"></polyline>
							<line x1="9" y1="15" x2="15" y2="15"></line>
						</svg>
					</div>
					<span class="font-display text-xl font-bold text-white">
						Oriz<span class="text-blue-400">PDF</span>
					</span>
				</a>
				<p class="text-sm leading-relaxed mb-4 max-w-xs">
					Every PDF tool you need. Free. Fast. Private. All processing
					happens in your browser — nothing is ever uploaded to a server.
				</p>
				<div class="flex gap-3">
					<a
						href="https://github.com/chirag127/orizpdf"
						target="_blank"
						rel="noopener noreferrer"
						class="size-9 flex items-center justify-center rounded-lg bg-gray-800 hover:bg-gray-700 transition-colors"
						aria-label="GitHub"
					>
						<svg
							class="size-4"
							fill="currentColor"
							viewBox="0 0 24 24"
						>
							<path
								d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
							></path>
						</svg>
					</a>
					<a
						href="https://twitter.com/chirag127"
						target="_blank"
						rel="noopener noreferrer"
						class="size-9 flex items-center justify-center rounded-lg bg-gray-800 hover:bg-gray-700 transition-colors"
						aria-label="Twitter"
					>
						<svg
							class="size-4"
							fill="currentColor"
							viewBox="0 0 24 24"
						>
							<path
								d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
							></path>
						</svg>
					</a>
				</div>
			</div>

			<!-- Tool Categories -->
			{
				categories.slice(0, 3).map((cat) => (
					<div>
						<h3 class="font-semibold text-white text-sm mb-4">
							{cat.label}
						</h3>
						<ul class="space-y-2">
							{tools
								.filter((t) => t.category === cat.id)
								.slice(0, 6)
								.map((tool) => (
									<li>
										<a
											href={`/tools/${tool.slug}`}
											class="text-sm hover:text-white transition-colors"
										>
											{tool.name}
										</a>
									</li>
								))}
						</ul>
					</div>
				))
			}
		</div>

		<!-- Bottom Bar -->
		<div
			class="mt-12 pt-8 border-t border-gray-800 flex flex-col sm:flex-row items-center justify-between gap-4"
		>
			<p class="text-sm">
				&copy; {year} OrizPDF. All rights reserved.
			</p>
			<div class="flex items-center gap-6 text-sm">
				<a href="/privacy" class="hover:text-white transition-colors"
					>Privacy Policy</a
				>
				<a href="/terms" class="hover:text-white transition-colors"
					>Terms of Service</a
				>
				<a href="/about" class="hover:text-white transition-colors">About</a>
			</div>
		</div>
	</div>
</footer>
