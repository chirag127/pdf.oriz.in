---
import { tools, categories } from "../../data/tools";
import { ChevronDown, Search, Menu } from "lucide-react";
---

<header
	class="sticky top-0 z-50 w-full border-b border-gray-200/80 bg-white/95 backdrop-blur-md"
>
	<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
		<div class="flex h-16 items-center justify-between">
			<!-- Logo -->
			<a href="/" class="flex items-center gap-2" aria-label="OrizPDF Home">
				<div class="flex items-center justify-center size-9 rounded-lg bg-blue-600 text-white">
					<svg
						viewBox="0 0 24 24"
						class="size-5"
						fill="none"
						stroke="currentColor"
						stroke-width="2.5"
						stroke-linecap="round"
						stroke-linejoin="round"
					>
						<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"
						></path>
						<polyline points="14 2 14 8 20 8"></polyline>
						<line x1="9" y1="15" x2="15" y2="15"></line>
					</svg>
				</div>
				<span class="font-display text-xl font-bold tracking-tight text-gray-900">
					Oriz<span class="text-blue-600">PDF</span>
				</span>
			</a>

			<!-- Desktop Navigation -->
			<nav class="hidden md:flex items-center gap-1">
				<!-- Tools Dropdown -->
				<div class="relative" id="tools-menu-container">
					<button
						id="tools-menu-trigger"
						class="flex items-center gap-1 px-3 py-2 text-sm font-medium text-gray-700 rounded-lg hover:bg-gray-100 transition-colors"
						aria-expanded="false"
						aria-haspopup="true"
					>
						Tools
						<ChevronDown className="size-4 transition-transform duration-200" />
					</button>

					<!-- Mega Menu -->
					<div
						id="tools-mega-menu"
						class="absolute left-1/2 -translate-x-1/2 top-full mt-2 w-[680px] p-4 bg-white rounded-xl shadow-lg border border-gray-200 opacity-0 invisible pointer-events-none transition-all duration-200 -translate-y-2"
						role="menu"
					>
						<div class="grid grid-cols-3 gap-4">
							{
								categories.map((cat) => (
									<div>
										<h3 class="text-xs font-semibold uppercase tracking-wider text-gray-500 mb-2 px-2">
											{cat.label}
										</h3>
										<ul class="space-y-0.5">
											{tools
												.filter((t) => t.category === cat.id)
												.map((tool) => (
													<li>
														<a
															href={`/tools/${tool.slug}`}
															class="flex items-center gap-2 px-2 py-1.5 rounded-lg text-sm text-gray-700 hover:bg-blue-50 hover:text-blue-700 transition-colors"
															role="menuitem"
														>
															<span
																class="size-6 rounded-md flex items-center justify-center text-xs font-medium"
																style={`background-color: ${tool.bgColor}; color: ${tool.color};`}
															>
																{tool.name.charAt(0)}
															</span>
															{tool.name}
														</a>
													</li>
												))}
										</ul>
									</div>
								))
							}
						</div>
					</div>
				</div>

				<a
					href="/blog"
					class="px-3 py-2 text-sm font-medium text-gray-700 rounded-lg hover:bg-gray-100 transition-colors"
				>
					Blog
				</a>
				<a
					href="/about"
					class="px-3 py-2 text-sm font-medium text-gray-700 rounded-lg hover:bg-gray-100 transition-colors"
				>
					About
				</a>
			</nav>

			<!-- Right Actions -->
			<div class="flex items-center gap-2">
				<button
					id="search-trigger"
					class="hidden sm:flex items-center gap-2 px-3 py-1.5 text-sm text-gray-500 bg-gray-100 rounded-lg hover:bg-gray-200 transition-colors"
					aria-label="Search tools"
				>
					<Search className="size-4" />
					<span class="hidden lg:inline">Search...</span>
					<kbd
						class="hidden lg:inline-flex items-center px-1.5 py-0.5 text-[10px] font-mono bg-white rounded border border-gray-300"
					>
						⌘K
					</kbd>
				</button>

				<a
					href="/tools/merge-pdf"
					class="hidden sm:inline-flex items-center gap-1.5 px-4 py-2 text-sm font-semibold text-white bg-blue-600 rounded-lg hover:bg-blue-700 transition-all hover:-translate-y-px hover:shadow-md"
				>
					Upload
				</a>

				<!-- Mobile Menu Button -->
				<button
					id="mobile-menu-trigger"
					class="md:hidden flex items-center justify-center size-10 rounded-lg hover:bg-gray-100 transition-colors"
					aria-label="Open menu"
					aria-expanded="false"
				>
					<Menu className="size-5 text-gray-700" />
				</button>
			</div>
		</div>
	</div>

	<!-- Search Modal -->
	<div
		id="search-modal"
		class="fixed inset-0 z-[60] bg-black/50 backdrop-blur-sm opacity-0 invisible pointer-events-none transition-opacity duration-200"
	>
		<div class="flex items-start justify-center pt-[15vh] px-4">
			<div
				class="w-full max-w-lg bg-white rounded-xl shadow-2xl overflow-hidden transform scale-95 opacity-0 transition-transform duration-200"
				id="search-panel"
			>
				<div class="flex items-center gap-3 px-4 py-3 border-b border-gray-200">
					<Search className="size-5 text-gray-400" />
					<input
						type="text"
						id="search-input"
						placeholder="Search tools..."
						class="flex-1 text-base outline-none placeholder:text-gray-400"
						autocomplete="off"
					/>
					<kbd
						class="px-2 py-1 text-xs font-mono bg-gray-100 rounded border border-gray-300 text-gray-500"
					>
						ESC
					</kbd>
				</div>
				<div id="search-results" class="max-h-80 overflow-y-auto p-2">
					<div class="px-3 py-6 text-center text-sm text-gray-500">
						Type to search across all tools
					</div>
				</div>
			</div>
		</div>
	</div>

	<!-- Mobile Menu -->
	<div
		id="mobile-menu"
		class="fixed inset-0 z-[55] md:hidden translate-x-full transition-transform duration-300"
	>
		<div
			class="absolute inset-0 bg-black/50"
			id="mobile-menu-backdrop"
		>
		</div>
		<div
			class="absolute right-0 top-0 bottom-0 w-80 max-w-[85vw] bg-white shadow-xl overflow-y-auto"
		>
			<div class="p-4 border-b border-gray-200 flex items-center justify-between">
				<span class="font-display text-lg font-bold">Menu</span>
				<button
					id="mobile-menu-close"
					class="size-10 flex items-center justify-center rounded-lg hover:bg-gray-100"
					aria-label="Close menu"
				>
					<svg
						class="size-5"
						fill="none"
						viewBox="0 0 24 24"
						stroke="currentColor"
						stroke-width="2"
					>
						<path d="M6 18L18 6M6 6l12 12"></path>
					</svg>
				</button>
			</div>
			<nav class="p-4 space-y-1">
				{
					categories.map((cat) => (
						<details class="group">
							<summary class="flex items-center justify-between px-3 py-2.5 text-sm font-semibold text-gray-900 rounded-lg hover:bg-gray-100 cursor-pointer list-none">
								{cat.label}
								<ChevronDown className="size-4 text-gray-400 group-open:rotate-180 transition-transform" />
							</summary>
							<ul class="ml-2 mt-1 space-y-0.5">
								{tools
									.filter((t) => t.category === cat.id)
									.map((tool) => (
										<li>
											<a
												href={`/tools/${tool.slug}`}
												class="flex items-center gap-2 px-3 py-2 text-sm text-gray-600 rounded-lg hover:bg-blue-50 hover:text-blue-700"
											>
												<span
													class="size-5 rounded flex items-center justify-center text-[10px] font-medium"
													style={`background-color: ${tool.bgColor}; color: ${tool.color};`}
												>
													{tool.name.charAt(0)}
												</span>
												{tool.name}
											</a>
										</li>
									))}
							</ul>
						</details>
					))
				}
				<div class="pt-3 mt-3 border-t border-gray-200 space-y-1">
					<a
						href="/blog"
						class="block px-3 py-2.5 text-sm font-medium text-gray-700 rounded-lg hover:bg-gray-100"
						>Blog</a
					>
					<a
						href="/about"
						class="block px-3 py-2.5 text-sm font-medium text-gray-700 rounded-lg hover:bg-gray-100"
						>About</a
					>
				</div>
			</nav>
		</div>
	</div>
</header>

<script>
	// Tools mega menu
	const trigger = document.getElementById("tools-menu-trigger");
	const menu = document.getElementById("tools-mega-menu");
	const container = document.getElementById("tools-menu-container");

	if (trigger && menu && container) {
		trigger.addEventListener("click", () => {
			const isOpen = menu.classList.contains("opacity-100");
			if (isOpen) {
				menu.classList.remove(
					"opacity-100",
					"visible",
					"pointer-events-auto",
					"translate-y-0",
				);
				menu.classList.add(
					"opacity-0",
					"invisible",
					"pointer-events-none",
					"-translate-y-2",
				);
				trigger.setAttribute("aria-expanded", "false");
			} else {
				menu.classList.add(
					"opacity-100",
					"visible",
					"pointer-events-auto",
					"translate-y-0",
				);
				menu.classList.remove(
					"opacity-0",
					"invisible",
					"pointer-events-none",
					"-translate-y-2",
				);
				trigger.setAttribute("aria-expanded", "true");
			}
		});

		document.addEventListener("click", (e) => {
			if (!container.contains(e.target as Node)) {
				menu.classList.remove(
					"opacity-100",
					"visible",
					"pointer-events-auto",
					"translate-y-0",
				);
				menu.classList.add(
					"opacity-0",
					"invisible",
					"pointer-events-none",
					"-translate-y-2",
				);
				trigger.setAttribute("aria-expanded", "false");
			}
		});
	}

	// Search modal
	const searchTrigger = document.getElementById("search-trigger");
	const searchModal = document.getElementById("search-modal");
	const searchPanel = document.getElementById("search-panel");
	const searchInput = document.getElementById("search-input");

	function openSearch() {
		searchModal?.classList.remove("opacity-0", "invisible", "pointer-events-none");
		searchModal?.classList.add("opacity-100", "visible", "pointer-events-auto");
		searchPanel?.classList.remove("scale-95", "opacity-0");
		searchPanel?.classList.add("scale-100", "opacity-100");
		searchInput?.focus();
	}

	function closeSearch() {
		searchModal?.classList.add("opacity-0", "invisible", "pointer-events-none");
		searchModal?.classList.remove("opacity-100", "visible", "pointer-events-auto");
		searchPanel?.classList.add("scale-95", "opacity-0");
		searchPanel?.classList.remove("scale-100", "opacity-100");
	}

	searchTrigger?.addEventListener("click", openSearch);
	searchModal?.addEventListener("click", (e) => {
		if (e.target === searchModal) closeSearch();
	});
	document.addEventListener("keydown", (e) => {
		if ((e.metaKey || e.ctrlKey) && e.key === "k") {
			e.preventDefault();
			openSearch();
		}
		if (e.key === "Escape") closeSearch();
	});

	// Search filtering
	const searchResults = document.getElementById("search-results");
	const TOOLS = [
		{ slug: "merge-pdf", name: "Merge PDF", desc: "Combine multiple PDFs" },
		{ slug: "split-pdf", name: "Split PDF", desc: "Extract pages from PDF" },
		{ slug: "compress-pdf", name: "Compress PDF", desc: "Reduce file size" },
		{ slug: "rotate-pdf", name: "Rotate PDF", desc: "Rotate PDF pages" },
		{ slug: "pdf-to-jpg", name: "PDF to JPG", desc: "Convert PDF to images" },
		{ slug: "jpg-to-pdf", name: "JPG to PDF", desc: "Convert images to PDF" },
		{ slug: "word-to-pdf", name: "Word to PDF", desc: "Convert DOCX to PDF" },
		{ slug: "pdf-to-word", name: "PDF to Word", desc: "Convert PDF to DOCX" },
		{ slug: "excel-to-pdf", name: "Excel to PDF", desc: "Convert XLSX to PDF" },
		{ slug: "pdf-to-excel", name: "PDF to Excel", desc: "Convert PDF to XLSX" },
		{ slug: "add-watermark", name: "Add Watermark", desc: "Stamp text on pages" },
		{ slug: "add-page-numbers", name: "Add Page Numbers", desc: "Number your pages" },
		{ slug: "protect-pdf", name: "Protect PDF", desc: "Add password protection" },
		{ slug: "unlock-pdf", name: "Unlock PDF", desc: "Remove password" },
		{ slug: "ocr-pdf", name: "OCR PDF", desc: "Make scanned PDFs searchable" },
		{ slug: "ai-summarizer", name: "AI Summarizer", desc: "AI-powered analysis" },
		{ slug: "remove-pages", name: "Remove Pages", desc: "Delete unwanted pages" },
		{ slug: "extract-pages", name: "Extract Pages", desc: "Pull out specific pages" },
		{ slug: "organize-pdf", name: "Organize PDF", desc: "Reorder PDF pages" },
		{ slug: "crop-pdf", name: "Crop PDF", desc: "Trim page margins" },
		{ slug: "sign-pdf", name: "Sign PDF", desc: "Add digital signatures" },
		{ slug: "redact-pdf", name: "Redact PDF", desc: "Black out content" },
		{ slug: "compare-pdf", name: "Compare PDF", desc: "Side-by-side diff" },
		{ slug: "repair-pdf", name: "Repair PDF", desc: "Fix corrupted files" },
		{ slug: "optimize-pdf", name: "Optimize PDF", desc: "Clean and optimize" },
		{ slug: "scan-to-pdf", name: "Scan to PDF", desc: "Camera document scan" },
		{ slug: "html-to-pdf", name: "HTML to PDF", desc: "Convert HTML to PDF" },
		{ slug: "pdf-to-pdfa", name: "PDF to PDF/A", desc: "Archival format" },
		{ slug: "powerpoint-to-pdf", name: "PowerPoint to PDF", desc: "Convert PPTX to PDF" },
		{ slug: "pdf-to-powerpoint", name: "PDF to PowerPoint", desc: "Convert PDF to PPTX" },
	];

	searchInput?.addEventListener("input", (e) => {
		const query = (e.target as HTMLInputElement).value.toLowerCase().trim();
		if (!query) {
			searchResults!.innerHTML = `<div class="px-3 py-6 text-center text-sm text-gray-500">Type to search across all tools</div>`;
			return;
		}

		const matches = TOOLS.filter(
			(t) =>
				t.name.toLowerCase().includes(query) ||
				t.desc.toLowerCase().includes(query),
		);

		if (matches.length === 0) {
			searchResults!.innerHTML = `<div class="px-3 py-6 text-center text-sm text-gray-500">No tools found for "${query}"</div>`;
			return;
		}

		searchResults!.innerHTML = matches
			.map(
				(t) => `
			<a href="/tools/${t.slug}" class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-blue-50 transition-colors">
				<span class="text-sm font-medium text-gray-900">${t.name}</span>
				<span class="text-xs text-gray-500">${t.desc}</span>
			</a>
		`,
			)
			.join("");
	});

	// Mobile menu
	const mobileTrigger = document.getElementById("mobile-menu-trigger");
	const mobileMenu = document.getElementById("mobile-menu");
	const mobileClose = document.getElementById("mobile-menu-close");
	const mobileBackdrop = document.getElementById("mobile-menu-backdrop");

	function openMobile() {
		mobileMenu?.classList.remove("translate-x-full");
		document.body.style.overflow = "hidden";
		mobileTrigger?.setAttribute("aria-expanded", "true");
	}

	function closeMobile() {
		mobileMenu?.classList.add("translate-x-full");
		document.body.style.overflow = "";
		mobileTrigger?.setAttribute("aria-expanded", "false");
	}

	mobileTrigger?.addEventListener("click", openMobile);
	mobileClose?.addEventListener("click", closeMobile);
	mobileBackdrop?.addEventListener("click", closeMobile);
</script>
