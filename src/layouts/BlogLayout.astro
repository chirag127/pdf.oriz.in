---
import BaseLayout from "./BaseLayout.astro";

interface Props {
  title: string;
  description: string;
  date: string;
  category?: string;
  image?: string;
  author?: string;
  readingTime?: string;
}

const {
  title,
  description,
  date,
  category = "PDF Tips",
  image,
  author = "OrizPDF Team",
  readingTime = "5 min read",
} = Astro.props;

const formattedDate = new Date(date).toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const canonical = Astro.url.pathname;
---

<BaseLayout title={`${title} | OrizPDF Blog`} description={description} canonical={canonical}>
  <article class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 py-12">
    <header class="mb-10">
      <div class="flex items-center gap-3 mb-4">
        {category && (
          <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
            {category}
          </span>
        )}
        <time datetime={date} class="text-sm text-gray-500">{formattedDate}</time>
        <span class="text-sm text-gray-400">•</span>
        <span class="text-sm text-gray-500">{readingTime}</span>
      </div>
      <h1 class="text-4xl sm:text-5xl font-bold text-gray-900 leading-tight mb-4">
        {title}
      </h1>
      <p class="text-xl text-gray-600 leading-relaxed">
        {description}
      </p>
      <div class="mt-6 flex items-center gap-3">
        <div class="w-10 h-10 rounded-full bg-gradient-to-br from-blue-500 to-purple-600 flex items-center justify-center text-white font-bold text-sm">
          {author[0]}
        </div>
        <div>
          <p class="text-sm font-medium text-gray-900">{author}</p>
          <p class="text-xs text-gray-500">Published on {formattedDate}</p>
        </div>
      </div>
    </header>

    {image && (
      <div class="mb-10 rounded-2xl overflow-hidden">
        <img
          src={image}
          alt={title}
          class="w-full h-64 sm:h-80 object-cover"
          loading="lazy"
        />
      </div>
    )}

    <div class="prose prose-lg prose-blue max-w-none prose-headings:scroll-mt-20 prose-a:text-blue-600 prose-a:no-underline hover:prose-a:underline prose-img:rounded-xl prose-code:bg-gray-100 prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded prose-code:before:content-[''] prose-code:after:content-['']">
      <slot />
    </div>

    <footer class="mt-16 pt-8 border-t border-gray-200">
      <div class="flex flex-wrap items-center justify-between gap-4">
        <div>
          <p class="text-sm text-gray-500">Written by {author}</p>
        </div>
        <div class="flex items-center gap-2">
          <span class="text-sm text-gray-500">Share:</span>
          <a href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(`https://pdf.oriz.in${canonical}`)}`} target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-blue-500 transition-colors">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          <a href={`https://www.linkedin.com/shareArticle?mini=true&url=${encodeURIComponent(`https://pdf.oriz.in${canonical}`)}&title=${encodeURIComponent(title)}`} target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-blue-700 transition-colors">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
        </div>
      </div>
    </footer>
  </article>
</BaseLayout>

<style>
  .prose :global(h2) {
    font-size: 1.75rem;
    font-weight: 700;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    color: #111827;
  }
  .prose :global(h3) {
    font-size: 1.375rem;
    font-weight: 600;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    color: #1f2937;
  }
  .prose :global(p) {
    line-height: 1.8;
    color: #374151;
  }
  .prose :global(ul), .prose :global(ol) {
    line-height: 1.8;
  }
  .prose :global(blockquote) {
    border-left: 4px solid #3b82f6;
    background: #eff6ff;
    padding: 1rem 1.5rem;
    border-radius: 0 0.5rem 0.5rem 0;
    font-style: italic;
  }
</style>
