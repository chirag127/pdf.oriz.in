---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="404 — Page Not Found | OrizPDF" description="Page not found. Explore our free PDF tools.">
	<section class="min-h-[60vh] flex items-center justify-center">
		<div class="text-center px-4">
			<h1 class="font-display text-6xl font-bold text-gray-900 mb-4">404</h1>
			<p class="text-xl text-gray-600 mb-8">The page you're looking for doesn't exist.</p>
			<a href="/" class="inline-flex items-center gap-2 px-6 py-3 bg-blue-600 text-white font-semibold rounded-lg hover:bg-blue-700 transition-all">
				Go Home
			</a>
		</div>
	</section>
</BaseLayout>