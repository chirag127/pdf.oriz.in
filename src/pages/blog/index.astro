const pageTitle = "Blog | OrizPDF — PDF Tips, Guides & Tutorials";
const pageDescription = "Expert guides and tutorials on PDF tools, document management, and productivity. Learn how to merge, split, compress, convert, and edit PDFs.";
---

<BaseLayout title={pageTitle} description={pageDescription} canonical="/blog">
  <div class="bg-gradient-to-b from-blue-50 to-white">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16">
      <div class="text-center mb-12">
        <h1 class="text-4xl sm:text-5xl font-bold text-gray-900 mb-4">
          OrizPDF Blog
        </h1>
        <p class="text-xl text-gray-600 max-w-2xl mx-auto">
          Expert guides, tips, and tutorials on PDF tools and document management.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {posts.map((post) => (
          <a
            href={`/blog/${post.slug}`}
            class="group block bg-white rounded-2xl border border-gray-200 overflow-hidden hover:shadow-lg hover:border-blue-200 transition-all duration-200"
          >
            <div class="p-6">
              <div class="flex items-center gap-2 mb-3">
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
                  {post.category}
                </span>
                <time class="text-xs text-gray-500">{post.date}</time>
              </div>
              <h2 class="text-lg font-bold text-gray-900 group-hover:text-blue-600 transition-colors mb-2 line-clamp-2">
                {post.title}
              </h2>
              <p class="text-sm text-gray-600 line-clamp-3">
                {post.description}
              </p>
            </div>
            <div class="px-6 pb-4">
              <span class="text-sm font-medium text-blue-600 group-hover:text-blue-700 flex items-center gap-1">
                Read more
                <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M9 5l7 7-7 7" />
                </svg>
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </div>
</BaseLayout>
