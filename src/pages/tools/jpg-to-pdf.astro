---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ToolHeader from "../../components/tools/ToolHeader.astro";
import { ToolSidebar } from "../../components/tools/ToolSidebar";
import { ToolFAQ } from "../../components/tools/ToolFAQ";
import { getToolBySlug } from "../../data/tools";
const tool = getToolBySlug("jpg-to-pdf")!;
const faqs = [
	{ question: "What image formats are supported?", answer: "JPG, JPEG, PNG, and WebP images are supported. Each image becomes a separate page in the PDF." },
	{ question: "Can I set the page size?", answer: "Yes, choose A4, Letter, or 'Fit' which uses the image's original dimensions." },
	{ question: "Are images scaled to fit the page?", answer: "Yes, images are automatically scaled to fit within the selected page size while maintaining aspect ratio." },
	{ question: "Can I combine multiple images into one PDF?", answer: "Yes, upload multiple images at once. Each image will become a separate page in the PDF." },
	{ question: "Is image quality preserved?", answer: "Yes, images are embedded at high quality. The 'Fit' option preserves the original resolution exactly." },
];
---
<BaseLayout title="JPG to PDF Online — Free & No Upload | OrizPDF" description="Convert JPG, PNG, and WebP images to PDF. Set page size and combine multiple images. Free, private, browser-based." canonical="/tools/jpg-to-pdf">
	<ToolHeader toolName={tool.name} toolSlug={tool.slug} category={tool.category} description={tool.description} />
	<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-10">
		<div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
			<div class="lg:col-span-2"><div id="tool-mount"><div class="flex items-center justify-center min-h-[300px]"><div class="size-8 border-2 border-blue-600 border-t-transparent rounded-full animate-spin mx-auto mb-3"></div><p class="text-sm text-gray-500">Loading...</p></div></div><article class="mt-12 prose prose-gray max-w-none"><h2>How to Convert Images to PDF</h2><p>Converting images to PDF is useful for creating document portfolios, submitting scanned forms, or sharing photo collections in a universally readable format.</p></article><ToolFAQ client:load items={faqs} toolName={tool.name} /></div>
			<div class="lg:col-span-1"><ToolSidebar client:load currentSlug="jpg-to-pdf" /></div>
		</div>
	</div>
</BaseLayout>
<script>import { createElement } from "react"; import { createRoot } from "react-dom/client"; import JPGtoPDF from "../../tools/JPGtoPDF"; const m = document.getElementById("tool-mount"); if (m) createRoot(m).render(createElement(JPGtoPDF));</script>
