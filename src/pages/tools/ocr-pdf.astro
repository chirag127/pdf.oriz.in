---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ToolHeader from "../../components/tools/ToolHeader.astro";
import { ToolSidebar } from "../../components/tools/ToolSidebar";
import { ToolFAQ } from "../../components/tools/ToolFAQ";
import { getToolBySlug } from "../../data/tools";
const tool = getToolBySlug("ocr-pdf")!;
const faqs = [
	{ question: "What does OCR do?", answer: "OCR (Optical Character Recognition) converts scanned images of text into actual selectable and searchable text." },
	{ question: "What languages are supported?", answer: "English is currently supported. More languages coming soon." },
	{ question: "Does it work on already searchable PDFs?", answer: "The tool will still process but won't change text that is already selectable." },
];
---
<BaseLayout title="OCR PDF Online — Free & No Upload | OrizPDF" description="Make scanned PDFs searchable with OCR. Extract text from images. Free, private, browser-based." canonical="/tools/ocr-pdf">
	<ToolHeader toolName={tool.name} toolSlug={tool.slug} category={tool.category} description={tool.description} />
	<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-10">
		<div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
			<div class="lg:col-span-2"><div id="tool-mount"><div class="flex items-center justify-center min-h-[300px]"><div class="size-8 border-2 border-blue-600 border-t-transparent rounded-full animate-spin mx-auto mb-3"></div><p class="text-sm text-gray-500">Loading...</p></div></div><article class="mt-12 prose prose-gray max-w-none"><h2>How OCR Works</h2><p>Optical Character Recognition analyzes each page image and identifies text, converting it to selectable characters. The output is a PDF with searchable text layers.</p></article><ToolFAQ client:load items={faqs} toolName={tool.name} /></div>
			<div class="lg:col-span-1"><ToolSidebar client:load currentSlug="ocr-pdf" /></div>
		</div>
	</div>
</BaseLayout>
<script>import { createElement } from "react"; import { createRoot } from "react-dom/client"; import OCRPDF from "../../tools/OCRPDF"; const m = document.getElementById("tool-mount"); if (m) createRoot(m).render(createElement(OCRPDF));</script>