---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ToolHeader from "../../components/tools/ToolHeader.astro";
import { ToolSidebar } from "../../components/tools/ToolSidebar";
import { ToolFAQ } from "../../components/tools/ToolFAQ";
import { getToolBySlug } from "../../data/tools";
const tool = getToolBySlug("optimize-pdf")!;
const faqs = [
	{ question: "What's the difference between optimize and compress?", answer: "Compress focuses on reducing file size. Optimize cleans metadata and optimizes the internal PDF structure." },
	{ question: "Will I lose any content?", answer: "No, optimization preserves all content while cleaning up metadata and redundant structures." },
];
---
<BaseLayout title="Optimize PDF Online — Free & No Upload | OrizPDF" description="Clean metadata and optimize PDF structure. Remove unnecessary data for smaller, cleaner files. Free, private, browser-based." canonical="/tools/optimize-pdf">
	<ToolHeader toolName={tool.name} toolSlug={tool.slug} category={tool.category} description={tool.description} />
	<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-10">
		<div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
			<div class="lg:col-span-2"><div id="tool-mount"><div class="flex items-center justify-center min-h-[300px]"><div class="size-8 border-2 border-blue-600 border-t-transparent rounded-full animate-spin mx-auto mb-3"></div><p class="text-sm text-gray-500">Loading...</p></div></div><article class="mt-12 prose prose-gray max-w-none"><h2>How to Optimize a PDF</h2><p>Clean up your PDFs by removing unnecessary metadata, optimizing internal structures, and reducing redundant data. This results in cleaner, more efficient PDF files.</p></article><ToolFAQ client:load items={faqs} toolName={tool.name} /></div>
			<div class="lg:col-span-1"><ToolSidebar client:load currentSlug="optimize-pdf" /></div>
		</div>
	</div>
</BaseLayout>
<script>import { createElement } from "react"; import { createRoot } from "react-dom/client"; import OptimizePDF from "../../tools/OptimizePDF"; const m = document.getElementById("tool-mount"); if (m) createRoot(m).render(createElement(OptimizePDF));</script>
