---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ToolHeader from "../../components/tools/ToolHeader.astro";
import { ToolSidebar } from "../../components/tools/ToolSidebar";
import { ToolFAQ } from "../../components/tools/ToolFAQ";
import { getToolBySlug } from "../../data/tools";

const tool = getToolBySlug("organize-pdf")!;
const title = "Organize PDF Pages — Reorder, Delete & Arrange | OrizPDF";
const description = "Easily reorder PDF pages with drag and drop. Delete unwanted pages, extract specific pages, and organize your document exactly how you want it.";

const faqs = [
	{ question: "How do I reorder pages in my PDF?", answer: "Simply upload your PDF, then drag and drop the page thumbnails to rearrange them in the order you need. Click the delete icon to remove any pages you don't want." },
	{ question: "Can I preview pages before reordering?", answer: "Yes. After uploading, you'll see thumbnail previews of each page. This lets you see exactly what content is on each page before deciding where to move it." },
	{ question: "Will page numbers update automatically?", answer: "The visual page numbers in our tool reflect the new order. If you need to add formal page numbers to your PDF, use our Add Page Numbers tool after organizing." },
	{ question: "Is there a limit to how many pages I can organize?", answer: "You can organize PDFs with hundreds of pages. Very large documents may take longer to load and process." },
];

const articleContent = `
<h2>How to Organize PDF Pages</h2>
<p>Our PDF organizer lets you rearrange, delete, and extract pages from any PDF document. All processing happens in your browser — your files never leave your device.</p>

<h3>Why Organize Your PDFs?</h3>
<p>Keeping your PDF documents properly organized makes them easier to navigate, share, and archive. Whether you're preparing a presentation, combining reports, or cleaning up scanned documents, page organization is essential.</p>

<h3>How It Works</h3>
<p>Upload your PDF, preview all pages as thumbnails, then drag and drop to reorder. Delete pages by clicking the remove button. When you're done, download your newly organized PDF.</p>
`;
---

<BaseLayout title={title} description={description} canonical="/tools/organize-pdf">
	<ToolHeader
		toolName={tool.name}
		toolSlug={tool.slug}
		category={tool.category}
		description={tool.description}
	/>

	<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-10">
		<div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
			<div class="lg:col-span-2">
				<div id="tool-mount">
					<div class="flex items-center justify-center min-h-[300px]">
						<div class="text-center">
							<div class="size-8 border-2 border-green-600 border-t-transparent rounded-full animate-spin mx-auto mb-3"></div>
							<p class="text-sm text-gray-500">Loading tool...</p>
						</div>
					</div>
				</div>

				<article class="mt-12 prose prose-gray max-w-none" set:html={articleContent} />
				<ToolFAQ client:load items={faqs} toolName={tool.name} />
			</div>

			<div class="lg:col-span-1">
				<ToolSidebar client:load currentSlug="organize-pdf" />
			</div>
		</div>
	</div>
</BaseLayout>

<script>
	import { createElement } from "react";
	import { createRoot } from "react-dom/client";
	import OrganizePDF from "../../tools/OrganizePDF";

	const mount = document.getElementById("tool-mount");
	if (mount) {
		createRoot(mount).render(createElement(OrganizePDF));
	}
</script>
