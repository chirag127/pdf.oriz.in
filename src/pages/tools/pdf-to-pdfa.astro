---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ToolHeader from "../../components/tools/ToolHeader.astro";
import { ToolSidebar } from "../../components/tools/ToolSidebar";
import { ToolFAQ } from "../../components/tools/ToolFAQ";
import { getToolBySlug } from "../../data/tools";

const tool = getToolBySlug("pdf-to-pdfa")!;
const title = "Convert to PDF/A — Archival PDF Format | OrizPDF";
const description = "Convert your PDF to PDF/A format for long-term archiving. Meets ISO standards for document preservation.";

const faqs = [
	{ question: "What is PDF/A?", answer: "PDF/A is an ISO-standardized version of PDF designed for long-term preservation of electronic documents. It ensures documents will remain readable in the future." },
	{ question: "Which PDF/A version is used?", answer: "We convert to PDF/A-1b compatible format, which ensures visual appearance is preserved over time." },
	{ question: "Can I convert password-protected PDFs?", answer: "No, please unlock the PDF first using our Unlock PDF tool." },
];

const articleContent = `
<h2>Convert to PDF/A</h2>
<p>PDF/A is the gold standard for document archival. Convert your PDFs to ensure they remain accessible and maintain their visual integrity for decades.</p>
`;
---

<BaseLayout title={title} description={description} canonical="/tools/pdf-to-pdfa">
	<ToolHeader toolName={tool.name} toolSlug={tool.slug} category={tool.category} description={tool.description} />
	<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-10">
		<div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
			<div class="lg:col-span-2">
				<div id="tool-mount">
					<div class="flex items-center justify-center min-h-[300px]">
						<div class="text-center">
							<div class="size-8 border-2 border-stone-600 border-t-transparent rounded-full animate-spin mx-auto mb-3"></div>
							<p class="text-sm text-gray-500">Loading tool...</p>
						</div>
					</div>
				</div>
				<article class="mt-12 prose prose-gray max-w-none" set:html={articleContent} />
				<ToolFAQ client:load items={faqs} toolName={tool.name} />
			</div>
			<div class="lg:col-span-1"><ToolSidebar client:load currentSlug="pdf-to-pdfa" /></div>
		</div>
	</div>
</BaseLayout>

<script>
	import { createElement } from "react";
	import { createRoot } from "react-dom/client";
	import PDFToPDFA from "../../tools/PDFToPDFA";

	const mount = document.getElementById("tool-mount");
	if (mount) {
		createRoot(mount).render(createElement(PDFToPDFA));
	}
</script>
