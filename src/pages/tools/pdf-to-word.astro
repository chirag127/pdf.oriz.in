---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ToolHeader from "../../components/tools/ToolHeader.astro";
import { ToolSidebar } from "../../components/tools/ToolSidebar";
import { ToolFAQ } from "../../components/tools/ToolFAQ";
import { getToolBySlug } from "../../data/tools";

const tool = getToolBySlug("pdf-to-word")!;
const title = "Convert PDF to Word — Free Online | OrizPDF";
const description = "Extract text from PDF and convert to editable Word documents. Keep formatting and edit your content in Word.";

const faqs = [
	{ question: "Will formatting be preserved?", answer: "Basic formatting like paragraphs and line structure is preserved. Complex layouts may require minor adjustments in Word." },
	{ question: "Can I convert scanned PDFs?", answer: "Scanned PDFs require OCR. Use our OCR PDF tool first to make scanned documents searchable, then convert to Word." },
	{ question: "Are images preserved?", answer: "This tool focuses on text extraction. For image-rich documents, consider using PDF to JPG for visual conversion." },
];

const articleContent = `
<h2>Convert PDF to Word</h2>
<p>Turn your PDF documents into editable Word files. Extract text and formatting to create documents you can modify and customize.</p>
`;
---

<BaseLayout title={title} description={description} canonical="/tools/pdf-to-word">
	<ToolHeader toolName={tool.name} toolSlug={tool.slug} category={tool.category} description={tool.description} />
	<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-10">
		<div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
			<div class="lg:col-span-2">
				<div id="tool-mount">
					<div class="flex items-center justify-center min-h-[300px]">
						<div class="text-center">
							<div class="size-8 border-2 border-sky-600 border-t-transparent rounded-full animate-spin mx-auto mb-3"></div>
							<p class="text-sm text-gray-500">Loading tool...</p>
						</div>
					</div>
				</div>
				<article class="mt-12 prose prose-gray max-w-none" set:html={articleContent} />
				<ToolFAQ client:load items={faqs} toolName={tool.name} />
			</div>
			<div class="lg:col-span-1"><ToolSidebar client:load currentSlug="pdf-to-word" /></div>
		</div>
	</div>
</BaseLayout>

<script>
	import { createElement } from "react";
	import { createRoot } from "react-dom/client";
	import PDFToWord from "../../tools/PDFToWord";

	const mount = document.getElementById("tool-mount");
	if (mount) {
		createRoot(mount).render(createElement(PDFToWord));
	}
</script>
