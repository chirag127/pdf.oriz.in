---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ToolHeader from "../../components/tools/ToolHeader.astro";
import { ToolSidebar } from "../../components/tools/ToolSidebar";
import { ToolFAQ } from "../../components/tools/ToolFAQ";
import { getToolBySlug } from "../../data/tools";
const tool = getToolBySlug("remove-pages")!;
const faqs = [
	{ question: "How do I specify pages to remove?", answer: "Enter page numbers separated by commas, e.g., '1,3,5' to remove pages 1, 3, and 5." },
	{ question: "Does removing pages renumber the remaining pages?", answer: "No, the original page numbers remain. Use Add Page Numbers to add new numbers." },
	{ question: "Can I remove all pages except one?", answer: "Yes, specify all pages except the one you want to keep, e.g., '1,2,4,5' to keep page 3." },
];
---
<BaseLayout title="Remove Pages from PDF — Free & No Upload | OrizPDF" description="Delete unwanted pages from PDF files. Select specific pages to remove. Free, private, browser-based." canonical="/tools/remove-pages">
	<ToolHeader toolName={tool.name} toolSlug={tool.slug} category={tool.category} description={tool.description} />
	<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-10">
		<div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
			<div class="lg:col-span-2"><div id="tool-mount"><div class="flex items-center justify-center min-h-[300px]"><div class="size-8 border-2 border-blue-600 border-t-transparent rounded-full animate-spin mx-auto mb-3"></div><p class="text-sm text-gray-500">Loading...</p></div></div><article class="mt-12 prose prose-gray max-w-none"><h2>How to Remove Pages from PDF</h2><p>Quickly delete unwanted pages from any PDF. Simply enter the page numbers you want to remove and download the cleaned-up document.</p></article><ToolFAQ client:load items={faqs} toolName={tool.name} /></div>
			<div class="lg:col-span-1"><ToolSidebar client:load currentSlug="remove-pages" /></div>
		</div>
	</div>
</BaseLayout>
<script>import { createElement } from "react"; import { createRoot } from "react-dom/client"; import RemovePages from "../../tools/RemovePages"; const m = document.getElementById("tool-mount"); if (m) createRoot(m).render(createElement(RemovePages));</script>
