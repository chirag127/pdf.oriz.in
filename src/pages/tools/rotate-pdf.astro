---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ToolHeader from "../../components/tools/ToolHeader.astro";
import { ToolSidebar } from "../../components/tools/ToolSidebar";
import { ToolFAQ } from "../../components/tools/ToolFAQ";
import { getToolBySlug } from "../../data/tools";
const tool = getToolBySlug("rotate-pdf")!;
const faqs = [
	{ question: "Can I rotate just specific pages?", answer: "Yes! Choose 'Specific pages' and enter page numbers separated by commas (e.g., 1,3,5)." },
	{ question: "What rotation angles are available?", answer: "You can rotate pages by 90°, 180°, or 270° clockwise." },
	{ question: "Can I rotate a PDF that's already been rotated?", answer: "Yes, rotation is cumulative. A 90° rotation applied twice equals 180°." },
	{ question: "Does rotation affect page content quality?", answer: "No, rotation only changes the page orientation. Text and images remain at their original quality." },
	{ question: "Can I undo a rotation?", answer: "Simply rotate the page by the opposite angle (e.g., rotate 270° to undo a 90° rotation)." },
];
---
<BaseLayout title="Rotate PDF Online — Free & No Upload | OrizPDF" description="Rotate PDF pages clockwise or counterclockwise. Choose specific pages or rotate all at once. Free, private, browser-based." canonical="/tools/rotate-pdf">
	<ToolHeader toolName={tool.name} toolSlug={tool.slug} category={tool.category} description={tool.description} />
	<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-10">
		<div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
			<div class="lg:col-span-2">
				<div id="tool-mount"><div class="flex items-center justify-center min-h-[300px]"><div class="size-8 border-2 border-blue-600 border-t-transparent rounded-full animate-spin mx-auto mb-3"></div><p class="text-sm text-gray-500">Loading...</p></div></div>
				<article class="mt-12 prose prose-gray max-w-none"><h2>How to Rotate PDF Pages</h2><p>Scanned documents often end up in the wrong orientation. Our free PDF rotator lets you fix this in seconds. Rotate all pages at once or select specific pages to adjust individually.</p><h3>Common Use Cases</h3><ul><li>Fixing upside-down scanned pages</li><li>Rotating landscape pages to portrait</li><li>Correcting pages scanned sideways</li></ul></article>
				<ToolFAQ client:load items={faqs} toolName={tool.name} />
			</div>
			<div class="lg:col-span-1"><ToolSidebar client:load currentSlug="rotate-pdf" /></div>
		</div>
	</div>
</BaseLayout>
<script>import { createElement } from "react"; import { createRoot } from "react-dom/client"; import RotatePDF from "../../tools/RotatePDF"; const m = document.getElementById("tool-mount"); if (m) createRoot(m).render(createElement(RotatePDF));</script>
